# =============================================================================
# Trading Lab — SECRETS ONLY
# =============================================================================
# Copy to .env, fill in, and NEVER commit.
#
# Non-secret configuration lives in `config/`:
#   - config/system.yaml     — log level, watcher thresholds, budgets
#   - config/venues.yaml     — endpoint URLs, contract addresses
#   - config/portfolio.yaml  — risk envelope, capital allocations
#
# Validate your setup:  make check-env
# =============================================================================

# -----------------------------------------------------------------------------
# Live trading security gate
# -----------------------------------------------------------------------------
# Set to `true` ONLY when you're ready to submit real orders. The runner
# refuses to start any live deployment without this. Note that paper-vs-live
# is now a per-strategy concern (hypothesis lifecycle state) — this env
# var is the global "I really mean it" guard.
LIVE_TRADING_CONFIRMED=false

# -----------------------------------------------------------------------------
# Polymarket credentials  (prefix POLY_)
# -----------------------------------------------------------------------------

# L1: Ethereum/Polygon private key for EIP-712 signing.
# Format: hex string, with or without 0x prefix. REQUIRED for any trading.
POLY_PRIVATE_KEY=0x...

# L2: API credentials — derived once via `make derive-keys`, then cached here.
# Optional for backtest + paper (public endpoints only); REQUIRED for live.
# If your Polymarket tradable wallet differs from the signer EOA, also set:
#   POLY_FUNDER=<wallet/profile/proxy/deposit address shown in Polymarket Settings>
#   POLY_SIGNATURE_TYPE=<0|1|2|3>
# Common cases:
#   0 = standalone EOA
#   2 = Polymarket UI-created Gnosis Safe / proxy wallet
#   3 = deposit wallet / POLY_1271
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
POLY_FUNDER=
POLY_SIGNATURE_TYPE=0

# -----------------------------------------------------------------------------
# Hyperliquid credentials  (prefix HL_)
# -----------------------------------------------------------------------------
# Optional — only required if a strategy uses Hyperliquid (none active yet).

HL_PRIVATE_KEY=0x...

# Main account address (vault/sub-account if using agent wallet).
# Leave blank to derive from HL_PRIVATE_KEY at runtime.
HL_ACCOUNT_ADDRESS=
