# =============================================================================
# Nautilus-Predict — Environment Configuration
# =============================================================================
# Copy this file: cp .env.example .env
# Fill in your credentials. NEVER commit .env to version control.
#
# Validate your setup:  make check-env
# =============================================================================

# -----------------------------------------------------------------------------
# System
# -----------------------------------------------------------------------------
TRADING_MODE=paper              # live | paper | backtest  (default: paper)
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR

# Double opt-in guard for live trading.
# BOTH TRADING_MODE=live AND LIVE_TRADING_CONFIRMED=true must be set.
# Leave unset (or false) for paper/backtest modes.
LIVE_TRADING_CONFIRMED=false

# -----------------------------------------------------------------------------
# Polymarket (CLOB on Polygon — primary venue)
# Environment prefix: POLY_
# -----------------------------------------------------------------------------

# L1: Ethereum/Polygon private key for EIP-712 signing (derive L2 creds once)
# Format: hex string, with or without 0x prefix
# TODO(setup): Replace with your actual wallet private key
POLY_PRIVATE_KEY=0x...

# L2: API credentials — obtained once via `make derive-keys` or the
# Polymarket dashboard. Store these and reuse on subsequent runs.
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Polymarket endpoints (defaults shown, change only if using testnet)
POLY_HOST=https://clob.polymarket.com
POLY_WS_HOST=wss://ws-subscriptions-clob.polymarket.com/ws/

# Polygon RPC (required for on-chain settlement verification)
POLYGON_RPC_URL=https://polygon-rpc.com

# Polymarket CLOB contract addresses (Polygon mainnet — do not change)
POLYMARKET_CTF_ADDRESS=0x4D97DCd97eC945f40cF65F87097ACe5EA0476045
POLYMARKET_EXCHANGE_ADDRESS=0x4bFb41d5B3570DeFd03C39a9A4D8dE6Bd8B8982E

# -----------------------------------------------------------------------------
# Hyperliquid (Perpetuals DEX — price oracle and hedging venue)
# Environment prefix: HL_
# -----------------------------------------------------------------------------

# Agent wallet private key for signing Hyperliquid orders
# TODO(setup): Replace with your Hyperliquid agent wallet key
HL_PRIVATE_KEY=0x...

# Main account address (vault/sub-account if using agent wallet)
# Leave blank to use the address derived from HL_PRIVATE_KEY
HL_ACCOUNT_ADDRESS=

# Hyperliquid endpoints
HL_API_URL=https://api.hyperliquid.xyz
HL_WS_URL=wss://api.hyperliquid.xyz/ws

# -----------------------------------------------------------------------------
# Risk Management
# -----------------------------------------------------------------------------

# Maximum position size per market (USDC). Conservative default.
MAX_POSITION_USDC=100.0

# Maximum total portfolio exposure across all markets (USDC)
MAX_TOTAL_EXPOSURE_USDC=1000.0

# Kill switch triggers if daily PnL drops below this threshold.
# Must be negative. Example: -200.0 means halt if down $200 in a day.
DAILY_LOSS_LIMIT_USDC=-200.0

# Heartbeat timeout: cancel all orders if no heartbeat within N seconds
HEARTBEAT_TIMEOUT_SECS=10

# -----------------------------------------------------------------------------
# Strategy Parameters — Market Maker
# -----------------------------------------------------------------------------
# Minimum bid-ask spread to quote, in basis points (1 bps = 0.01%)
MM_SPREAD_BPS=50

# Per-side order size in USDC (e.g., 10 = $10 bid + $10 ask)
MM_ORDER_SIZE_USDC=10.0

# Maximum net position per market in USDC before quoting stops
MM_MAX_POSITION_USDC=500.0

# -----------------------------------------------------------------------------
# Strategy Parameters — Binary Complement Arbitrage
# -----------------------------------------------------------------------------
# Minimum required profit per arb (USDC) — accounts for fees and slippage
ARB_MIN_PROFIT_USDC=0.02

# Maximum capital to deploy per single arb opportunity (USDC)
ARB_MAX_CAPITAL_USDC=1000.0

# -----------------------------------------------------------------------------
# Strategy Parameters — Cross-Venue Hedging
# -----------------------------------------------------------------------------
# Fraction of Polymarket event exposure to hedge on Hyperliquid (0.0–1.0)
HEDGE_RATIO=0.5

# Hyperliquid instrument to use for hedging crypto event markets
HEDGE_INSTRUMENT=BTC-USD
