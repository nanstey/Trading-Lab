# =============================================================================
# Nautilus-Predict Environment Configuration
# Copy this file to .env and populate with real credentials.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# System
# -----------------------------------------------------------------------------
TRADING_MODE=paper          # live | paper | backtest
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR

# -----------------------------------------------------------------------------
# Polymarket (CLOB - Polygon network)
# -----------------------------------------------------------------------------
# L1: Ethereum private key used to sign EIP-712 messages and derive L2 creds
POLYMARKET_PRIVATE_KEY=0x...

# L2: API credentials (obtained via /auth/derive-api-key or generated manually)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Polymarket endpoints
POLYMARKET_HTTP_URL=https://clob.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/

# Polygon RPC (required for on-chain settlement verification)
POLYGON_RPC_URL=https://polygon-rpc.com

# Polymarket CLOB contract addresses (Polygon mainnet)
POLYMARKET_CTF_ADDRESS=0x4D97DCd97eC945f40cF65F87097ACe5EA0476045
POLYMARKET_EXCHANGE_ADDRESS=0x4bFb41d5B3570DeFd03C39a9A4D8dE6Bd8B8982E

# -----------------------------------------------------------------------------
# Hyperliquid (Perpetuals DEX - L1 chain)
# -----------------------------------------------------------------------------
# Ethereum private key for signing Hyperliquid orders (agent wallet)
HYPERLIQUID_PRIVATE_KEY=0x...

# Main account address (vault/sub-account if using agent wallet)
HYPERLIQUID_ACCOUNT_ADDRESS=

# Hyperliquid endpoints
HYPERLIQUID_HTTP_URL=https://api.hyperliquid.xyz
HYPERLIQUID_WS_URL=wss://api.hyperliquid.xyz/ws

# -----------------------------------------------------------------------------
# Strategy Parameters
# -----------------------------------------------------------------------------
# Market Making
MM_SPREAD_BPS=50            # Minimum spread in basis points
MM_ORDER_SIZE_USDC=10       # Per-side order size in USDC
MM_MAX_POSITION_USDC=500    # Maximum net position per market

# Binary Complement Arbitrage
ARB_MIN_PROFIT_USDC=0.02    # Minimum profit threshold per pair
ARB_MAX_CAPITAL_USDC=1000   # Max capital deployed per arb

# Cross-Venue Hedging
HEDGE_RATIO=0.5             # Fraction of Polymarket exposure to hedge on HL
HEDGE_INSTRUMENT=BTC-USD    # Hyperliquid instrument for hedging
